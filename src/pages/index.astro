---
import Layout from "../layouts/Layout.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="NC - Network Computing">
  <!-- ヒーローセクション -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-8">
        <!-- 左側：ロゴエリア -->
        <div class="w-full lg:w-1/2">
          <div class="bg-white p-12 rounded-lg shadow-lg text-center">
            <div class="text-6xl font-bold text-gray-800 mb-4">ロゴ</div>
            <div class="w-32 h-32 bg-gray-200 mx-auto rounded-lg"></div>
          </div>
        </div>

        <!-- 右側：テキスト -->
        <div class="w-full lg:w-1/2 text-center lg:text-center">
          <h1
            class="text-3xl lg:text-4xl font-bold text-gray-800 leading-tight"
          >
            みんなのアイデアを実現できる<br />
            プラットフォームを開発する
          </h1>
        </div>
      </div>
    </div>
  </section>

  <!-- NCとはセクション -->
  <section class="bg-teal-400 pb-32 pt-8">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-center text-black text-3xl font-bold mb-12">NCとは</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- カード1 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="font-bold text-lg mb-3 text-gray-800">
            Nekko Cloudを作る
          </h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            運営・設計・構築・運用のすべてを行う
          </p>
        </div>

        <!-- カード2 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="font-bold text-lg mb-3 text-gray-800">
            Nekko Cloudを利用する
          </h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Nekko Cloudを作るだけではなく、実際に利用する、<br />
            そうすることで，現状の課題を見つけて，次の開発につなげる．
          </p>
        </div>

        <!-- カード3 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="font-bold text-lg mb-3 text-gray-800">
            Nekko Cloudを通じて知見・知識を収集し、発表する
          </h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            本プロジェクトの知名度向上や，オープンソースへの貢献
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nekko Cloudテクノロジーセクション -->
  <section class="bg-teal-500 pb-32 pt-8">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-center text-black text-3xl font-bold mb-12">
        Nekko Cloudテクノロジー
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- HOGE 1 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="flex">
            <div class="w-1/2">
              <h3 class="font-bold text-lg mb-8 text-gray-800">Kubenetes</h3>
              <ul class="text-sm text-gray-600 space-y-1">
                <li>コンテナオーケストレーション</li>
                <li>Nekko Cloudの基盤技術を支える</li>
                <li>詳細</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- HOGE 2 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="font-bold text-lg mb-8 text-gray-800">Proxmox</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>VMなどを管理するOS</li>
            <li>仮想化技術でお役立ち</li>
            <li>詳細</li>
          </ul>
        </div>

        <!-- HOGE 3 -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="font-bold text-lg mb-8 text-gray-800">HOGE</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>hogehoge</li>
            <li>hogehoge</li>
            <li>pon</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- メディアセクション -->
  <section class="bg-teal-600 pb-32 pt-8">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-center text-black text-3xl font-bold mb-12">メディア</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Twitter カード1 -->
        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-4"></div>
          <p class="text-sm text-gray-600 mb-2">アイコン</p>
          <p class="font-semibold text-gray-800 mb-1">X</p>
          <p class="text-sm text-gray-500">@nekko_lab</p>
        </div>

        <!-- Twitter カード2 -->
        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-4"></div>
          <p class="text-sm text-gray-600 mb-2">アイコン</p>
          <p class="font-semibold text-gray-800 mb-1">Qiita</p>
          <p class="text-sm text-gray-500">@いるまる</p>
        </div>

        <!-- Twitter カード3 -->
        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto mb-4"></div>
          <p class="text-sm text-gray-600 mb-2">アイコン</p>
          <p class="font-semibold text-gray-800 mb-1">Instagram</p>
          <p class="text-sm text-gray-500">@ねっこ</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
