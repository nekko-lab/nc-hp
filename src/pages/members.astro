          { platform: 'instagram', url: '', username: 'wakki0123' },
          { platform: 'GitHub', url: '', username: 'wakki-0123' },
        ]}
        comment="視認性がとてもよい大柄な人です 人間の身体と精神に少し詳しいです"
      />
      <Graymember
        imageUrl="/member6.jpg"
        person="chiharu"
        position="役職:NCチーム開発メンバー"
        role="サービス開発"
        snsLinks={[
          { platform: 'X', url: '', username: '@chiharu_meow' },
          { platform: 'instagram', url: '', username: 'chiharu_meow' },
          { platform: 'GitHub', url: '', username: 'Chiharu-Hagihara' },
