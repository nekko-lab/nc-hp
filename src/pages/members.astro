---
import Whitemember from '../components/item/WhiteMember.astro';
import Graymember from '../components/item/GrayMember.astro';
import Pagetitle from '../components/page/pagetitle.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="メンバー | NC - Nekko Cloud">
  <Pagetitle title="メンバー" />
  <section class="py-16 min-h-screen">
    <div class="w-full px-8 2xl:px-24 mx-auto space-y-16">
      <Whitemember
        imageUrl="/member1.jpg"
        person="みらのん"
        position="役職:ネットワークコンテンツ研究会部長"
        role="PM,フロントエンド サービス開発"
        snsLinks={[
          {
            platform: 'X',
            url: 'https://x.com/Erica_kangeki',
            username: '@Erica_kangeki',
          },
          {
            platform: 'instagram',
            url: '',
            username: 'misoparco',
          },
          { platform: 'GitHub', url: '', username: 'miranop' },
        ]}
        comment="毎日頑張ります"
      />

      <Graymember
        imageUrl="/member2.png"
        person="Cyokozai"
        position="役職:NCチームプロダクトオーナー"
        role="PM,インフラ,サービス開発"
        snsLinks={[
          {
            platform: 'X',
            url: '',
            username: '@cyokozai0',
          },
        ]}
