---
// Navigation.astro
import { Image } from "astro:assets";
const currentPath = Astro.url.pathname;
import namelogo from "../../assets/nekko_cloud.logo-1.png";
---

<nav class="bg-teal-200 shadow-lg">
  <div class="w-full px-8 2xl:px-24 mx-auto">
    <div class="flex justify-between items-center py-4">
      <!-- ロゴ/サークル名 -->
      <div class="flex items-center">
        <a href="/" class="text-xl font-bold text-gray-800">
          <Image src={namelogo} alt="Nekko Cloud Logo" class="h-10 w-auto" />
        </a>
      </div>

      <!-- ナビゲーションメニュー -->
      <div class="hidden md:flex space-x-8">
        <a
          href="/"
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath === "/"
              ? "bg-blue-100 text-blue-700"
              : "text-gray-700 hover:text-blue-600 hover:bg-green-400"
          }`}
        >
          NCとは
        </a>

        <a
          href="/achievements"
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath === "/achievements"
              ? "bg-blue-100 text-blue-700"
              : "text-gray-700 hover:text-blue-600 hover:bg-green-400"
          }`}
        >
          活動実績
        </a>

        <a
          href="/members"
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath === "/members"
              ? "bg-blue-100 text-blue-700"
              : "text-gray-700 hover:text-blue-600 hover:bg-green-400"
          }`}
        >
          メンバー
        </a>

        <a
          href="/history"
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            currentPath === "/history"
              ? "bg-blue-100 text-blue-700"
              : "text-gray-700 hover:text-blue-600 hover:bg-green-400"
          }`}
        >
          歴史
        </a>
      </div>

      <!-- モバイルメニューボタン -->
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          class="text-gray-700 hover:text-blue-600"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- モバイルメニュー -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <a href="/" class="block px-3 py-2 text-gray-700 hover:bg-green-400"
        >ホーム</a
      >
      <a
        href="/achievements"
        class="block px-3 py-2 text-gray-700 hover:bg-green-400">実績</a
      >
      <a
        href="/members"
        class="block px-3 py-2 text-gray-700 hover:bg-green-400">メンバー</a
      >
      <a
        href="/history"
        class="block px-3 py-2 text-gray-700 hover:bg-green-400">歴史</a
      >
    </div>
  </div>

  <script>
    // モバイルメニューの切り替え
    document.addEventListener("DOMContentLoaded", () => {
      const button = document.getElementById("mobile-menu-button");
      const menu = document.getElementById("mobile-menu");

      button?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });
    });
  </script>
</nav>
