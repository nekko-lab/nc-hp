---
export interface Props {
  title: string;
  description: string;
  link?: string;
}
const { title, description, link } = Astro.props;
---

<div class="bg-white p-6 2xl:p-10 rounded-lg shadow-lg">
  <div class="flex">
    <div class="w-full">
      <h3
        class="font-bold text-2xl 2xl:text-2xl mb-8 text-gray-800 text-center"
      >
        {title}
      </h3>
      <ul class="text-xl text-gray-600 space-y-1 text-center">
        <li set:html={description} />
        {
          link && (
            <li>
              <a href={link}>詳細⇒</a>
            </li>
          )
        }
      </ul>
    </div>
  </div>
</div>
