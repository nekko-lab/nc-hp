---
import nonimage from "../../assets/nekko_cloud.logo-1.png";
export interface Props {
  imageUrl: string; // 文字列のままでOK
  title: string;
  description: string;
  date: string;
  link: string;
}
const { imageUrl, title, description, date, link } = Astro.props;
---

<div
  class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow"
>
  <div class="h-48 bg-gray-200">
    <img src={imageUrl || nonimage.src} class="w-full h-full object-cover" />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-gray-600 mb-4">{description}</p>
    <div class="flex flex-wrap gap-2 mb-4"></div>
    <p class="text-sm text-gray-500">{date}</p>

    <a
      href={link}
      class="font-bold text-blue-600 hover:text-blue-800 text-sm hover:underline mt-8
    inline-block"
      >詳細⇒
    </a>
  </div>
</div>
