---
export interface Props {
  year: number;
  month: number;
  content: string;
}
const { year, month, content } = Astro.props;
---

<div
  class="flex items-start gap-6 mb-8 hover:scale-110 transition-transform duration-300 cursor-pointer rounded-lg p-4 hover:bg-gray-50"
>
  <!-- タイムライン部分 -->
  <div class="flex flex-col items-center">
    <div
      class="w-4 h-4 bg-teal-400 rounded-full hover:scale-125 transition-transform duration-200"
    >
    </div>
    <div class="w-0.5 h-24 bg-gray-300 mt-2"></div>
  </div>

  <!-- コンテンツ部分 -->
  <div class="pt-0.5">
    <h3 class="text-2xl font-bold text-black-800 mb-1">{year}</h3>
    <p class="text-black-600 text-bold">{month}月{content}</p>
  </div>
</div>
