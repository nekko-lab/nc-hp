---
export interface Props {
  imageUrl: string;
  person: string;
  position: string;
  role: string;
  snsLinks: { platform: string; url: string; username: string }[];
  comment: string;
}
const { imageUrl, person, position, role, snsLinks, comment } = Astro.props;
---

<div class="bg-gray-200 p-8 shadow-lg mt-6">
  <div class="flex flex-col lg:flex-row items-center p-16">
    <div class="flex-1 text-center lg:text-left order-2 lg:order-1 lg:mr-8">
      <h3 class="text-2xl font-bold mb-2">{person}</h3>
      <p class="text-gray-700 mb-1">{position}</p>
      <p class="text-gray-700 mb-4">担当:{role}</p>
      <p class="text-gray-700">
        SNS名<br />
        {
          snsLinks.map((link) => (
            <span>
              {link.platform}:{link.username}
              <br />
            </span>
          ))
        }
      </p>
      <p class="text-black-600 my-10">{comment}</p>
    </div>
    <div
      class="w-64 h-64 bg-green-100 rounded-full flex items-center justify-center order-1 lg:order-2 overflow-hidden"
    >
      {
        imageUrl ? (
          <img src={imageUrl} alt={person} class="w-full h-full object-cover" />
        ) : (
          <span>アイコン</span>
        )
      }
    </div>
  </div>
</div>
